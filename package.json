  "homepage": "https://github.com/NSIS-Dev/scoop-nsis#readme",
  "dependencies": {
    "eta": "^3.5.0",
    "log-symbols": "^7.0.1"
  },
  "devDependencies": {
    "ava": "^5.3.1",
    "husky": "^8.0.3",
    "jsonlint": "^1.6.3",
    "lint-staged": "^13.3.0"
  },
  "ava": {
